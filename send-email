#!/bin/bash
# send-email — CLI tool for agents to send email
# Usage: send-email --to "recipient" --subject "Subject" --body "Body" --cc "cc@email.com"
#
# This is the ONLY way agents should send email.
# Handles: domain routing, scrubbing, formatting, CC enforcement, dedup, storage, indexing.

cd /home/aielevate

# Parse arguments
TO=""
SUBJECT=""
BODY=""
CC=""
AGENT_ID=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --to) TO="$2"; shift 2 ;;
        --subject) SUBJECT="$2"; shift 2 ;;
        --body) BODY="$2"; shift 2 ;;
        --cc) CC="$2"; shift 2 ;;
        --agent) AGENT_ID="$2"; shift 2 ;;
        --body-file) BODY=$(cat "$2"); shift 2 ;;
        *) shift ;;
    esac
done

if [ -z "$TO" ] || [ -z "$SUBJECT" ] || [ -z "$BODY" ]; then
    echo "Usage: send-email --to EMAIL --subject SUBJECT --body BODY [--cc CC] [--agent AGENT_ID]"
    echo "  or:  send-email --to EMAIL --subject SUBJECT --body-file FILE [--cc CC] [--agent AGENT_ID]"
    exit 1
fi

# Default agent ID from environment or fallback
AGENT_ID="${AGENT_ID:-${OPENCLAW_AGENT_ID:-gigforge}}"

# Call send_email.py which handles everything
python3 -c "
import sys; sys.path.insert(0, '/home/aielevate')
from send_email import send_email
result = send_email(
    to='''$TO''',
    subject='''$SUBJECT''',
    body='''$BODY''',
    agent_id='$AGENT_ID',
    cc='''$CC''',
)
print(result.get('status', 'error'))
"
